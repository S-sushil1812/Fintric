# ============================================================================
# FINTRIC - Environment Variables Template
# ============================================================================
# 
# IMPORTANT SECURITY NOTES:
# 1. This file (.env.example) contains NO actual secrets - it's safe to commit
# 2. Create a local .env file (NEVER commit this) with your actual credentials
# 3. Add .env to .gitignore to prevent accidental secret leaks
# 4. Use this template: cp .env.example .env
#
# For detailed setup instructions, see: ENV_SETUP_GUIDE.md
# ============================================================================

# ============================================================================
# GOOGLE GEMINI API - AI-Powered Features (RECOMMENDED)
# ============================================================================
# Enables intelligent transaction categorization and financial chatbot
# 
# Get your free API key at: https://makersuite.google.com/app/apikey
# - Visit the link above
# - Click "Create API Key"
# - Copy the generated key below
#
# Status: Recommended (app works without it, but AI features disabled)
#
GOOGLE_API_KEY=your_api_key_here


# ============================================================================
# GOOGLE OAUTH - Social Login Integration (OPTIONAL)
# ============================================================================
# Enable "Continue with Google" authentication option
# Users can still use username/password login without these variables
#
# Setup instructions: https://console.cloud.google.com/
# 1. Create a Google Cloud project
# 2. Enable Google+ API
# 3. Create OAuth 2.0 Web credentials
# 4. Copy the Client ID and Secret below
# 5. Configure the Redirect URI to match your deployment
#
# Status: Optional - all three must be set together to work
#

# OAuth Application Client ID
# Get from: https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_client_id_here

# OAuth Client Secret (SENSITIVE - Treat like a password)
# Get from: https://console.cloud.google.com
# ⚠️ NEVER commit your actual secret to git
GOOGLE_CLIENT_SECRET=your_client_secret_here

# OAuth Redirect URI - Must match configuration in Google Cloud Console
# Local Development: http://localhost:8501
# Streamlit Cloud: https://your-app.streamlit.app
# Custom Domain: https://yourdomain.com
GOOGLE_REDIRECT_URI=http://localhost:8501


# ============================================================================
# END OF ENVIRONMENT VARIABLES
# ============================================================================
